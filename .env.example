# ─── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Flask / Webhook ─────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change_me_to_a_random_string
WEBHOOK_SECRET=your_tradingview_webhook_secret   # add this as a query param in TV alert URL
PORT=5000

# ─── Optional: TradingView Webhook Auth ──────────────────────────────────────
# Set a hard-to-guess token and append ?secret=<WEBHOOK_SECRET> in every TV alert URL.
# The server validates this before processing any payload.
