// =============================================================================
// Gold Futures AMT Analyst - Fabervaale Framework
// Author  : Built for Fabervaale (Fabio Valentini) methodology
// Markets : XAUUSD / GC1! (Gold Futures)
// Concepts: Auction Market Theory, Volume Profile, Order Flow, CVD
//
// What it does:
//   1. Approximates a session Volume Profile (POC, VAH, VAL)
//   2. Calculates Cumulative Volume Delta (CVD) from bar OHLC estimation
//   3. Detects Balance vs Imbalance state
//   4. Classifies Initiative vs Responsive activity
//   5. Detects Absorption (high volume / low range)
//   6. Detects Delta Divergence
//   7. Fires a JSON webhook payload to your Python server
//
// IMPORTANT: TradingView Pine Script does not give tick-level bid/ask data.
//   CVD here uses an OHLC-based estimation (Upward-Close Volume fraction).
//   For true tick CVD, pair this with a Bookmap or Sierra Chart feed.
// =============================================================================

//@version=5
indicator(title="Gold AMT Analyst - Fabervaale Framework", shorttitle="AMT Gold", overlay=true, max_bars_back=500)

// --- INPUTS ------------------------------------------------------------------

// Volume Profile
vp_lookback    = input.int(30,   "VP Lookback (bars)",         minval=10, maxval=100, group="Volume Profile")
value_area_pct = input.float(70, "Value Area %",               minval=50, maxval=95,  group="Volume Profile")
vp_bins        = input.int(20,   "VP Price Bins",              minval=10, maxval=40,  group="Volume Profile")

// CVD
cvd_length     = input.int(20,   "CVD Smoothing Length",       minval=1,  maxval=50,  group="CVD")

// Signal thresholds
abs_vol_mult   = input.float(1.8, "Absorption Vol Multiplier", minval=1.0, maxval=5.0, group="Signals",
     tooltip="Bar volume must exceed avg x this to qualify as absorption")
abs_range_pct  = input.float(0.3, "Absorption Range % of ATR", minval=0.1, maxval=1.0, group="Signals",
     tooltip="Bar range must be less than this x ATR to qualify as absorption")
div_lookback   = input.int(5,    "Delta Divergence Lookback",  minval=2,  maxval=20,  group="Signals")

// Webhook
webhook_url_placeholder = input.string(
     "https://your-server.com/webhook?secret=YOUR_SECRET",
     "Webhook URL (replace with your server URL)",
     group="Webhook",
     tooltip="Paste your ngrok / VPS URL here. Alerts -> Message contains the JSON payload.")

// Display
show_poc     = input.bool(true, "Show POC",          group="Display")
show_vah_val = input.bool(true, "Show VAH/VAL",      group="Display")
show_cvd     = input.bool(true, "Show CVD Panel",    group="Display")
show_signals = input.bool(true, "Show Signal Labels", group="Display")

// --- VOLUME PROFILE APPROXIMATION --------------------------------------------
// VP is recalculated only on bar close (barstate.isconfirmed) and the
// results are stored in var variables so they persist into the next bar.
// This avoids recalculating on every intra-bar tick, which was the source
// of the RE10022 timeout.

var float[] _bin_vols = array.new_float(40, 0.0)  // pre-alloc for max bins

var float poc      = close
var float vah      = close
var float val      = close
var bool  hvn_near = false
var bool  lvn_near = false

if barstate.isconfirmed
    lo_range = ta.lowest(low,   vp_lookback)
    hi_range = ta.highest(high, vp_lookback)
    bin_size = hi_range - lo_range > 0 ? (hi_range - lo_range) / vp_bins : 1.0

    // Reset bins
    for b = 0 to vp_bins - 1
        array.set(_bin_vols, b, 0.0)

    // Accumulate volume into bins
    for i = 0 to vp_lookback - 1
        bar_mid = (high[i] + low[i]) / 2
        bin_idx = int(math.min(math.floor((bar_mid - lo_range) / bin_size), vp_bins - 1))
        if bin_idx >= 0
            array.set(_bin_vols, bin_idx, array.get(_bin_vols, bin_idx) + volume[i])

    // POC - O(1) lookup via array.indexof instead of a loop
    max_vol = array.max(_bin_vols)
    poc_bin = array.indexof(_bin_vols, max_vol)
    poc    := lo_range + (poc_bin + 0.5) * bin_size

    // Value Area - expand outward from POC, capped at vp_bins iterations
    total_vol = array.sum(_bin_vols)
    target    = total_vol * (value_area_pct / 100)
    captured  = array.get(_bin_vols, poc_bin)
    lo_bin    = poc_bin
    hi_bin    = poc_bin
    iters     = 0

    while captured < target and (lo_bin > 0 or hi_bin < vp_bins - 1) and iters < vp_bins
        lo_vol = lo_bin > 0            ? array.get(_bin_vols, lo_bin - 1) : 0.0
        hi_vol = hi_bin < vp_bins - 1  ? array.get(_bin_vols, hi_bin + 1) : 0.0
        if hi_vol >= lo_vol
            hi_bin   := hi_bin + 1
            captured += hi_vol
        else
            lo_bin   := lo_bin - 1
            captured += lo_vol
        iters += 1

    vah := lo_range + (hi_bin + 1) * bin_size
    val := lo_range + lo_bin        * bin_size

    // HVN / LVN - O(1): check only the single bin that price occupies
    cur_bin = int(math.min(math.floor((close - lo_range) / bin_size), vp_bins - 1))
    if cur_bin >= 0
        cur_vol  = array.get(_bin_vols, cur_bin)
        hvn_near := cur_vol >= max_vol * 0.75
        lvn_near := cur_vol <= max_vol * 0.25
    else
        hvn_near := false
        lvn_near := false

// --- CUMULATIVE VOLUME DELTA -------------------------------------------------
// Estimate buying vs selling volume using close position within the bar range.
// buy_vol  ~= volume * (close - low)  / (high - low)
// sell_vol ~= volume * (high - close) / (high - low)
// delta     = buy_vol - sell_vol

bar_range = high - low
buy_vol   = bar_range > 0 ? volume * (close - low)  / bar_range : volume * 0.5
sell_vol  = bar_range > 0 ? volume * (high - close) / bar_range : volume * 0.5
bar_delta = buy_vol - sell_vol

cvd     = ta.cum(bar_delta)
cvd_sma = ta.sma(cvd, cvd_length)

cvd_trend = cvd > cvd_sma ? "bullish" : cvd < cvd_sma ? "bearish" : "neutral"

// --- ABSORPTION DETECTION ----------------------------------------------------
// High volume + low price movement = institutional absorption

atr14     = ta.atr(14)
avg_vol   = ta.sma(volume, vp_lookback)
absorption = volume >= avg_vol * abs_vol_mult and bar_range <= atr14 * abs_range_pct

// --- BALANCE / IMBALANCE STATE -----------------------------------------------
// Market is IN BALANCE when price oscillates between VAH and VAL.
// IMBALANCED when it has been outside the value area consistently.

bars_above_vah = 0
bars_below_val = 0
for i = 0 to vp_lookback - 1
    if close[i] > vah
        bars_above_vah += 1
    if close[i] < val
        bars_below_val += 1

imbalance_threshold = int(vp_lookback * 0.6)

var string balance_state = "in_balance"
if bars_above_vah >= imbalance_threshold
    balance_state := "imbalanced_bullish"
else if bars_below_val >= imbalance_threshold
    balance_state := "imbalanced_bearish"
else if close > vah and close[1] <= vah[1]
    balance_state := "breaking_high"
else if close < val and close[1] >= val[1]
    balance_state := "breaking_low"
else
    balance_state := "in_balance"

// --- DELTA DIVERGENCE --------------------------------------------------------
// Price makes new high but CVD doesn't confirm -> bearish divergence
// Price makes new low  but CVD doesn't confirm -> bullish divergence

recent_hi = ta.highest(close, div_lookback)
recent_lo = ta.lowest(close,  div_lookback)
cvd_hi    = ta.highest(cvd,   div_lookback)
cvd_lo    = ta.lowest(cvd,    div_lookback)

bearish_div = close >= recent_hi and cvd < cvd_hi[1]
bullish_div = close <= recent_lo and cvd > cvd_lo[1]

delta_divergence = bearish_div ? "bearish_div" : bullish_div ? "bullish_div" : "none"

// --- SIGNAL LOGIC ------------------------------------------------------------
// Fabervaale's core signal types.

at_poc = math.abs(close - poc) <= atr14 * 0.5
at_vah = math.abs(close - vah) <= atr14 * 0.5
at_val = math.abs(close - val) <= atr14 * 0.5

// Responsive signals (price returning to value)
poc_rejection_long  = at_poc and bar_delta > 0 and close > open and balance_state == "in_balance"
poc_rejection_short = at_poc and bar_delta < 0 and close < open and balance_state == "in_balance"
val_bounce_long     = at_val and bar_delta > 0 and close > open
vah_rejection_short = at_vah and bar_delta < 0 and close < open

// Initiative signals (price pushing into new territory)
initiative_long  = balance_state == "breaking_high" and cvd_trend == "bullish" and volume >= avg_vol * 1.3
initiative_short = balance_state == "breaking_low"  and cvd_trend == "bearish" and volume >= avg_vol * 1.3

// Delta divergence signals (fade)
div_short = bearish_div and balance_state != "imbalanced_bullish"
div_long  = bullish_div and balance_state != "imbalanced_bearish"

// Absorption signals
absorption_long  = absorption and at_val and bar_delta > 0
absorption_short = absorption and at_vah and bar_delta < 0

// --- SIGNAL PRIORITY ---------------------------------------------------------
// Emit only one signal per bar (highest-priority first).

signal_type = initiative_long ? "initiative_breakout_long" : initiative_short ? "initiative_breakout_short" : div_short ? "delta_div_short" : div_long ? "delta_div_long" : absorption_long ? "absorption_long" : absorption_short ? "absorption_short" : val_bounce_long ? "val_bounce_long" : vah_rejection_short ? "vah_rejection_short" : poc_rejection_long ? "poc_rejection_long" : poc_rejection_short ? "poc_rejection_short" : ""

any_signal = signal_type != ""

// --- WEBHOOK PAYLOAD ---------------------------------------------------------
// Alert message is sent as JSON to your Flask server.

if any_signal
    payload = "{" +
        '"ticker":"'          + syminfo.ticker                   + '",' +
        '"price":'            + str.tostring(close,   "#.##")   + ','  +
        '"poc":'              + str.tostring(poc,     "#.##")   + ','  +
        '"vah":'              + str.tostring(vah,     "#.##")   + ','  +
        '"val":'              + str.tostring(val,     "#.##")   + ','  +
        '"cvd":'              + str.tostring(cvd,     "#.##")   + ','  +
        '"cvd_trend":"'       + cvd_trend                       + '",' +
        '"volume":'           + str.tostring(volume,  "#")      + ','  +
        '"avg_volume":'       + str.tostring(avg_vol, "#.##")   + ','  +
        '"balance_state":"'   + balance_state                   + '",' +
        '"signal_type":"'     + signal_type                     + '",' +
        '"absorption":'       + str.tostring(absorption)        + ','  +
        '"delta_divergence":"'+ delta_divergence                + '",' +
        '"hvn_near":'         + str.tostring(hvn_near)          + ','  +
        '"lvn_near":'         + str.tostring(lvn_near)          + ','  +
        '"timeframe":"'       + timeframe.period                + '"'  +
        "}"
    alert(payload, alert.freq_once_per_bar_close)

// --- VISUAL OVERLAYS ---------------------------------------------------------

poc_col = color.new(color.yellow, 0)
vah_col = color.new(color.green,  30)
val_col = color.new(color.red,    30)

poc_line = plot(show_poc     ? poc : na, "POC", poc_col, 2, plot.style_line)
vah_line = plot(show_vah_val ? vah : na, "VAH", vah_col, 1, plot.style_line)
val_line = plot(show_vah_val ? val : na, "VAL", val_col, 1, plot.style_line)

fill(vah_line, val_line, color=color.new(color.gray, 90), title="Value Area")

// Signal labels
if show_signals and any_signal
    lbl_color = str.contains(signal_type, "long")  ? color.green :
                str.contains(signal_type, "short") ? color.red   : color.gray
    lbl_text  = str.upper(str.replace(signal_type, "_", " "))
    label.new(bar_index, low * 0.9995,
              text=lbl_text, color=lbl_color, textcolor=color.white,
              style=label.style_label_up, size=size.tiny)

// Absorption markers
plotshape(absorption and show_signals, title="Absorption",
     style=shape.diamond, location=location.belowbar,
     color=color.new(color.orange, 0), size=size.small)

// Delta divergence markers
plotshape(bearish_div and show_signals, title="Bearish Div",
     style=shape.xcross, location=location.abovebar,
     color=color.new(color.red, 0), size=size.small)

plotshape(bullish_div and show_signals, title="Bullish Div",
     style=shape.xcross, location=location.belowbar,
     color=color.new(color.green, 0), size=size.small)

// Balance state background tint
bgcolor(balance_state == "imbalanced_bullish" ? color.new(color.green, 95) :
        balance_state == "imbalanced_bearish" ? color.new(color.red,   95) :
        na, title="Imbalance Background")

// --- CVD PANEL ---------------------------------------------------------------

cvd_col = cvd >= 0 ? color.new(color.green, 30) : color.new(color.red, 30)
plot(show_cvd ? cvd     : na, "CVD",     cvd_col,     2, plot.style_area, display=display.pane)
plot(show_cvd ? cvd_sma : na, "CVD SMA", color.white, 1,                  display=display.pane)

// --- TABLE: LIVE AMT DASHBOARD -----------------------------------------------

var table dashboard = table.new(
     position.top_right, 2, 7,
     bgcolor=color.new(color.black, 70), border_width=1, border_color=color.new(color.gray, 50))

f_cell(row, col, txt, txt_col) =>
    table.cell(dashboard, col, row, txt,
               text_color=txt_col, text_size=size.small, bgcolor=color.new(color.black, 70))

f_cell(0, 0, "AMT GOLD",      color.white)
f_cell(0, 1, syminfo.ticker,  color.yellow)
f_cell(1, 0, "State",         color.gray)
f_cell(1, 1, balance_state,
     balance_state == "imbalanced_bullish" ? color.green :
     balance_state == "imbalanced_bearish" ? color.red   : color.yellow)
f_cell(2, 0, "POC",           color.gray)
f_cell(2, 1, str.tostring(poc, "#.##"), color.yellow)
f_cell(3, 0, "VAH",           color.gray)
f_cell(3, 1, str.tostring(vah, "#.##"), color.green)
f_cell(4, 0, "VAL",           color.gray)
f_cell(4, 1, str.tostring(val, "#.##"), color.red)
f_cell(5, 0, "CVD",           color.gray)
f_cell(5, 1, cvd_trend,
     cvd_trend == "bullish" ? color.green :
     cvd_trend == "bearish" ? color.red   : color.white)
f_cell(6, 0, "Signal",        color.gray)
f_cell(6, 1, any_signal ? signal_type : "none",
     any_signal ? color.orange : color.gray)
